      "name": "Properties",
      "item": [
        {
          "name": "Search properties - paged",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Response has page envelope\", function () {",
                  "  pm.expect(json).to.have.property(\"data\").that.is.an(\"array\");",
                  "  pm.expect(json).to.have.property(\"pagination\");",
                  "  pm.expect(json.pagination).to.include.keys([\"page\", \"perPage\", \"prePage\", \"nextPage\", \"total\", \"totalPages\"]);",
                  "});",
                  "",
                  "if (json.data.length > 0) {",
                  "  pm.environment.set(\"propertyId\", json.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/properties?page={{page}}&size={{size}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "properties"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "size",
                  "value": "{{size}}"
                }
              ]
            },
            "description": "Returns a paged property list. Defaults in the backend are page=1 and size=20; this request uses environment variables so you can change them per run."
          },
          "response": []
        },
