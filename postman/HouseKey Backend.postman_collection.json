        {
          "name": "Get property detail",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Property detail has frontend-compatible shape\", function () {",
                  "  pm.expect(json).to.include.keys([",
                  "    \"id\", \"title\", \"desc\", \"propertyType\", \"propertyStatus\", \"city\", \"zipCode\",",
                  "    \"neighborhood\", \"street\", \"location\", \"formattedAddress\", \"features\", \"featured\",",
                  "    \"priceDollar\", \"priceEuro\", \"priceDinars\", \"bedrooms\", \"bathrooms\", \"garages\",",
                  "    \"area\", \"yearBuilt\", \"ratingsCount\", \"ratingsValue\", \"additionalFeatures\",",
                  "    \"gallery\", \"plans\", \"videos\", \"published\", \"lastUpdate\", \"views\", \"agentId\"",
                  "  ]);",
                  "});",
                  "",
                  "pm.environment.set(\"propertyId\", json.id);",
                  "if (json.agentId) {",
                  "  pm.environment.set(\"agentId\", json.agentId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/properties/{{propertyId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "properties",
                "{{propertyId}}"
              ]
            },
            "description": "Returns full property detail for the selected propertyId."
          },
          "response": []
        },
