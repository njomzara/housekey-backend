              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"Filtered response is paged\", function () {",
                  "  pm.expect(json.data).to.be.an(\"array\");",
                  "  pm.expect(json.pagination.total).to.be.a(\"number\");",
                  "});",
                  "",
                  "if (json.data.length > 0) {",
                  "  pm.environment.set(\"propertyId\", json.data[0].id);",
                  "  pm.test(\"First result matches sample filter intent\", function () {",
                  "    pm.expect(json.data[0].propertyType).to.eql(pm.environment.get(\"propertyType\"));",
                  "    pm.expect(json.data[0].city).to.eql(pm.environment.get(\"city\"));",
                  "  });",
